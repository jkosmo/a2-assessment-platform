# Azure deployment environment variables (production)
AZURE_SUBSCRIPTION_ID=<subscription-id>
AZURE_LOCATION=westeurope
AZURE_RESOURCE_GROUP=rg-a2-assessment-production
AZURE_APP_NAME_PREFIX=a2-assessment-platform
AZURE_APP_SERVICE_SKU=B1
AZURE_COST_CENTER=a2-assessment-platform
AZURE_OWNER=engineering
AUTH_MODE=entra
ENTRA_TENANT_ID=<tenant-id>
ENTRA_AUDIENCE=api://<api-app-id>
ENTRA_SYNC_GROUP_ROLES=true
ENTRA_GROUP_ROLE_MAP_JSON=<json-map>
LLM_MODE=stub
LLM_STUB_MODEL_NAME=stub-model-v1
ASSESSMENT_JOB_POLL_INTERVAL_MS=4000
ASSESSMENT_JOB_MAX_ATTEMPTS=3
OBSERVABILITY_ALERT_EMAIL=<ops-alerts@company.com>
QUEUE_BACKLOG_ALERT_THRESHOLD=5
LATENCY_ALERT_THRESHOLD_SECONDS=3
APPEAL_OVERDUE_ALERT_THRESHOLD=1
APPEAL_SLA_MONITOR_INTERVAL_MS=600000
BUDGET_CONTACT_EMAIL=<alerts@company.com>
MONTHLY_BUDGET_AMOUNT=40
