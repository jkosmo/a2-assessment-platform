# Azure deployment environment variables (production)
AZURE_SUBSCRIPTION_ID=<subscription-id>
AZURE_LOCATION=westeurope
AZURE_RESOURCE_GROUP=rg-a2-assessment-production
AZURE_APP_NAME_PREFIX=a2-assessment-platform
AZURE_APP_SERVICE_SKU=B1
AZURE_COST_CENTER=a2-assessment-platform
AZURE_OWNER=engineering
# Secret required in GitHub Environment: POSTGRES_ADMIN_PASSWORD
POSTGRES_ADMIN_USERNAME=a2platformadmin
POSTGRES_DATABASE_NAME=a2assessment
POSTGRES_VERSION=16
POSTGRES_SKU_NAME=Standard_D2ds_v5
POSTGRES_SKU_TIER=GeneralPurpose
POSTGRES_STORAGE_SIZE_GB=32
POSTGRES_BACKUP_RETENTION_DAYS=35
POSTGRES_GEO_REDUNDANT_BACKUP=Disabled
POSTGRES_HIGH_AVAILABILITY_MODE=Disabled
AUTH_MODE=entra
ENTRA_TENANT_ID=<tenant-id>
ENTRA_CLIENT_ID=<spa-client-id>
ENTRA_AUDIENCE=api://<api-app-id>
ENTRA_SYNC_GROUP_ROLES=true
ENTRA_GROUP_ROLE_MAP_JSON=<json-map>
LLM_MODE=stub
LLM_STUB_MODEL_NAME=stub-model-v1
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_TIMEOUT_MS=120000
AZURE_OPENAI_TEMPERATURE=0
AZURE_OPENAI_MAX_TOKENS=1200
AZURE_OPENAI_TOKEN_LIMIT_PARAMETER=auto
ASSESSMENT_JOB_POLL_INTERVAL_MS=4000
ASSESSMENT_JOB_MAX_ATTEMPTS=3
ASSESSMENT_JOB_LEASE_DURATION_MS=300000
ASSESSMENT_JOB_STUCK_THRESHOLD_MS=600000
APPEAL_FIRST_RESPONSE_SLA_HOURS=24
APPEAL_RESOLUTION_SLA_HOURS=72
APPEAL_AT_RISK_RATIO=0.75
OBSERVABILITY_ALERT_EMAIL=<ops-alerts@company.com>
QUEUE_BACKLOG_ALERT_THRESHOLD=5
LATENCY_ALERT_THRESHOLD_SECONDS=3
APPEAL_OVERDUE_ALERT_THRESHOLD=1
APPEAL_SLA_MONITOR_INTERVAL_MS=600000
PARTICIPANT_NOTIFICATION_CHANNEL=webhook
PARTICIPANT_NOTIFICATION_WEBHOOK_URL=<notification-webhook-url>
PARTICIPANT_NOTIFICATION_WEBHOOK_TIMEOUT_MS=5000
ACS_EMAIL_SENDER_DISPLAY_NAME=A2 Assessment Platform
PARTICIPANT_CONSOLE_DEBUG_MODE=false
DEFAULT_LOCALE=en-GB
BUDGET_CONTACT_EMAIL=<alerts@company.com>
MONTHLY_BUDGET_AMOUNT=40
