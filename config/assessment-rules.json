{
  "thresholds": {
    "totalMin": 70,
    "practicalMinPercent": 50,
    "mcqMinPercent": 60
  },
  "weights": {
    "practicalMaxScore": 70,
    "mcqMaxScore": 30
  },
  "manualReview": {
    "borderlineWindow": {
      "min": 67,
      "max": 73
    },
    "redFlagSeverities": [
      "high"
    ],
    "redFlagCodes": [
      "potential_sensitive_data",
      "policy_violation",
      "responsible_use_violation"
    ]
  },
  "llmDecisionReliability": {
    "unknownRedFlagHandling": "downgrade_to_unclassified",
    "unknownRedFlagCanonicalCode": "unclassified_model_warning",
    "canonicalRedFlags": {
      "insufficient_submission": [
        "insufficient_submission",
        "insufficient_content",
        "insufficient_submission_content",
        "incomplete_submission",
        "extremely_low_content",
        "low_content_quality",
        "missing_mcq_and_notes",
        "missing_iteration_and_qa",
        "missing_iteration_qa",
        "garbled_submission",
        "incoherent_submission",
        "non_coherent_language",
        "language_clarity",
        "language_mismatch",
        "clarity_issue",
        "misalignment",
        "r001",
        "r002"
      ],
      "potential_sensitive_data": [
        "potential_sensitive_data",
        "sensitive_data_exposure",
        "personal_data_exposure"
      ],
      "policy_violation": [
        "policy_violation",
        "compliance_violation",
        "unsafe_instruction",
        "unsafe_content"
      ],
      "responsible_use_violation": [
        "responsible_use_violation",
        "responsible_use_risk"
      ]
    }
  },
  "mcqQuality": {
    "minAttemptCount": 5,
    "difficultyMin": 0.2,
    "difficultyMax": 0.9,
    "discriminationMin": 0.1
  },
  "sensitiveData": {
    "enabledByDefault": false,
    "moduleOverrides": {},
    "rules": [
      {
        "id": "email",
        "pattern": "[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}",
        "flags": "gi",
        "replacement": "[MASKED_EMAIL]"
      },
      {
        "id": "phone",
        "pattern": "(?:\\+?\\d[\\d\\s-]{6,}\\d)",
        "flags": "g",
        "replacement": "[MASKED_PHONE]"
      },
      {
        "id": "national-id",
        "pattern": "\\b\\d{11}\\b",
        "flags": "g",
        "replacement": "[MASKED_ID]"
      }
    ]
  },
  "secondaryAssessment": {
    "enabledByDefault": true,
    "moduleOverrides": {},
    "triggerRules": {
      "manualReviewRecommended": true,
      "confidenceNotePatterns": [
        "medium confidence",
        "low confidence"
      ],
      "redFlagCodes": [
        "potential_sensitive_data",
        "policy_violation",
        "responsible_use_violation"
      ],
      "redFlagSeverities": [
        "medium",
        "high"
      ]
    },
    "disagreementRules": {
      "practicalScoreDeltaMin": 8,
      "rubricTotalDeltaMin": 3,
      "passFailMismatch": true,
      "manualReviewRecommendationMismatch": true
    }
  },
  "recertification": {
    "validityDays": 365,
    "dueOffsetDays": 30,
    "dueSoonDays": 14,
    "reminderDaysBefore": [
      30,
      7,
      1
    ]
  }
}
