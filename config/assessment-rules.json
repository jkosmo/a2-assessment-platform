{
  "thresholds": {
    "totalMin": 70,
    "practicalMinPercent": 50,
    "mcqMinPercent": 60
  },
  "weights": {
    "practicalMaxScore": 70,
    "mcqMaxScore": 30
  },
  "manualReview": {
    "borderlineWindow": {
      "min": 67,
      "max": 73
    },
    "redFlagSeverities": [
      "high"
    ]
  },
  "mcqQuality": {
    "minAttemptCount": 5,
    "difficultyMin": 0.2,
    "difficultyMax": 0.9,
    "discriminationMin": 0.1
  },
  "sensitiveData": {
    "enabledByDefault": false,
    "moduleOverrides": {},
    "rules": [
      {
        "id": "email",
        "pattern": "[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}",
        "flags": "gi",
        "replacement": "[MASKED_EMAIL]"
      },
      {
        "id": "phone",
        "pattern": "(?:\\+?\\d[\\d\\s-]{6,}\\d)",
        "flags": "g",
        "replacement": "[MASKED_PHONE]"
      },
      {
        "id": "national-id",
        "pattern": "\\b\\d{11}\\b",
        "flags": "g",
        "replacement": "[MASKED_ID]"
      }
    ]
  },
  "secondaryAssessment": {
    "enabledByDefault": true,
    "moduleOverrides": {},
    "triggerRules": {
      "manualReviewRecommended": true,
      "confidenceNotePatterns": [
        "medium confidence",
        "low confidence"
      ],
      "redFlagSeverities": [
        "medium",
        "high"
      ]
    },
    "disagreementRules": {
      "practicalScoreDeltaMin": 8,
      "rubricTotalDeltaMin": 3,
      "passFailMismatch": true,
      "manualReviewRecommendationMismatch": true
    }
  },
  "recertification": {
    "validityDays": 365,
    "dueOffsetDays": 30,
    "dueSoonDays": 14,
    "reminderDaysBefore": [
      30,
      7,
      1
    ]
  }
}
