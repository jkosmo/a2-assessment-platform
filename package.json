{
  "name": "a2-assessment-platform",
  "version": "0.10.24",
  "private": true,
  "description": "Internal assessment platform backend bootstrap (M0 foundation).",
  "type": "module",
  "scripts": {
    "dev": "npm run postgres:setup && dotenv -e .env.postgres.local -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node scripts/runtime/startup.mjs",
    "postgres:setup": "node scripts/postgres/localSetup.mjs setup",
    "postgres:start": "node scripts/postgres/localSetup.mjs start",
    "postgres:stop": "node scripts/postgres/localSetup.mjs stop",
    "postgres:status": "node scripts/postgres/localSetup.mjs status",
    "postgres:verify": "node scripts/postgres/localSetup.mjs verify",
    "postgres:write-env": "node scripts/postgres/localSetup.mjs write-env",
    "postgres:recreate": "node scripts/postgres/localSetup.mjs recreate",
    "postgres:destroy": "node scripts/postgres/localSetup.mjs destroy",
    "postgres:prisma:generate": "node scripts/postgres/appBootstrap.mjs generate-client",
    "postgres:app:reset": "node scripts/postgres/appBootstrap.mjs reset-dev",
    "postgres:test:reset": "node scripts/postgres/appBootstrap.mjs reset-test",
    "postgres:app:seed": "node scripts/postgres/appBootstrap.mjs seed-dev",
    "postgres:test:seed": "node scripts/postgres/appBootstrap.mjs seed-test",
    "postgres:app:smoke": "node scripts/postgres/appBootstrap.mjs smoke-dev",
    "postgres:test:smoke": "node scripts/postgres/appBootstrap.mjs smoke-test",
    "postgres:app:bootstrap": "node scripts/postgres/appBootstrap.mjs bootstrap",
    "db:reset": "node scripts/runtime/prismaCommand.mjs migrate reset --force --skip-seed",
    "db:migrate": "node scripts/runtime/prismaCommand.mjs migrate deploy",
    "db:migrate:runtime": "node scripts/runtime/prismaCommand.mjs migrate deploy",
    "prisma:generate": "node scripts/runtime/prismaCommand.mjs generate",
    "prisma:migrate": "npm run db:migrate",
    "prisma:deploy": "npm run db:migrate",
    "bootstrap:seed": "node scripts/runtime/bootstrapSeed.mjs",
    "prisma:seed": "tsx prisma/seed.ts",
    "pretest": "npm run postgres:start && dotenv -e .env.test -- npm run db:reset && dotenv -e .env.test -- tsx prisma/seed.ts",
    "test": "dotenv -e .env.test -- vitest run",
    "test:unit": "dotenv -e .env.test -- vitest run --config vitest.unit.config.ts",
    "test:dom": "dotenv -e .env.test -- vitest run --config vitest.dom.config.ts",
    "test:admin-content:dom": "dotenv -e .env.test -- vitest run --config vitest.dom.config.ts test/dom/admin-content-workspaces.dom.test.js",
    "test:e2e:admin-content": "playwright test --config playwright.admin-content.config.ts",
    "test:e2e:admin-content:headed": "playwright test --config playwright.admin-content.config.ts --headed",
    "test:integration": "dotenv -e .env.test -- vitest run --config vitest.integration.config.ts",
    "test:integration:local": "dotenv -e .env.test -- vitest run --config vitest.integration.config.ts test/m1-core-flow.test.ts test/m2-participant-results-history.test.ts test/assessment-policy.integration.test.ts test/m2-manual-review.test.ts test/m2-appeal-flow.test.ts test/m2-admin-content-publication.test.ts test/m2-calibration-workspace.test.ts test/m2-module-archive.test.ts test/m2-source-material-extract.test.ts",
    "test:integration:core": "dotenv -e .env.test -- vitest run --config vitest.integration.config.ts test/m1-core-flow.test.ts test/m2-participant-results-history.test.ts test/assessment-policy.integration.test.ts",
    "test:integration:policy": "dotenv -e .env.test -- vitest run --config vitest.integration.config.ts test/assessment-policy.integration.test.ts test/m2-participant-results-history.test.ts",
    "test:integration:review": "dotenv -e .env.test -- vitest run --config vitest.integration.config.ts test/m2-manual-review.test.ts test/m2-appeal-flow.test.ts",
    "test:integration:admin": "dotenv -e .env.test -- vitest run --config vitest.integration.config.ts test/m2-admin-content-publication.test.ts test/m2-calibration-workspace.test.ts test/m2-module-archive.test.ts",
    "test:integration:contracts": "dotenv -e .env.test -- vitest run test/participant-console-config.test.ts test/workspace-html-fallbacks.test.js test/workspace-validation-accessibility.test.js test/admin-content-translations.test.js test/participant-translations.test.js test/calibration-translations.test.js test/participant-completed-translations.test.js",
    "test:assessment:batch": "tsx src/scripts/runAssessmentBatchRegression.ts",
    "benchmark:models": "tsx src/scripts/runModelComparisonBenchmark.ts",
    "parser:dev": "dotenv -e .env.postgres.local -- tsx watch src/parserApp.ts",
    "smoke:web": "node scripts/azure/smoke-web-runtime.mjs",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/communication-email": "^1.1.0",
    "@prisma/client": "6.5.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "jose": "^6.1.0",
    "mammoth": "^1.11.0",
    "officeparser": "^6.1.0",
    "pdf-parse": "^2.4.5",
    "ppt": "^0.0.2",
    "prisma": "^6.5.0",
    "word-extractor": "^1.0.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^8.0.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "supertest": "^7.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
