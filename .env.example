NODE_ENV=development
PORT=3000
DATABASE_URL=file:./dev.db

# auth modes: mock | entra
AUTH_MODE=mock

# used in AUTH_MODE=entra
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_AUDIENCE=api://assessment-platform-api
ENTRA_GROUP_ROLE_MAP_JSON={}
ENTRA_GROUP_ROLE_MAP_FILE=config/entra-group-role-map.example.json
ENTRA_SYNC_GROUP_ROLES=false

# used in AUTH_MODE=mock
MOCK_DEFAULT_USER_ID=dev-user-1
MOCK_DEFAULT_EMAIL=dev.user@company.com
MOCK_DEFAULT_NAME=Dev User
MOCK_DEFAULT_DEPARTMENT=Technology

# assessment
LLM_MODE=stub
LLM_STUB_MODEL_NAME=stub-model-v1
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_TIMEOUT_MS=30000
AZURE_OPENAI_TEMPERATURE=0
AZURE_OPENAI_MAX_TOKENS=1200
AZURE_OPENAI_TOKEN_LIMIT_PARAMETER=auto
PARTICIPANT_CONSOLE_CONFIG_FILE=config/participant-console.json
ASSESSMENT_RULES_FILE=config/assessment-rules.json
ASSESSMENT_JOB_POLL_INTERVAL_MS=4000
ASSESSMENT_JOB_MAX_ATTEMPTS=3
APPEAL_SLA_MONITOR_INTERVAL_MS=600000
APPEAL_OVERDUE_ALERT_THRESHOLD=1
PARTICIPANT_NOTIFICATION_CHANNEL=log
PARTICIPANT_NOTIFICATION_WEBHOOK_URL=
PARTICIPANT_NOTIFICATION_WEBHOOK_TIMEOUT_MS=5000
PARTICIPANT_CONSOLE_DEBUG_MODE=auto
